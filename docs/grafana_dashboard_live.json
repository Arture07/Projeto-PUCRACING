  "refresh": "500ms",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "PUCPR",
    "telemetry",
    "FSAE",
    "live"
  ],
  "templating": {
    "list": [
      {
        "name": "session_id",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "${DS_INFLUXDB}"
        },
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"telemetry\", tag: \"session_id\", predicate: (r) => r._measurement == \"telemetry_live\")",
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "source",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "${DS_INFLUXDB}"
        },
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"telemetry\", tag: \"source\", predicate: (r) => r._measurement == \"telemetry_live\")",
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
