        "textMode": "value",
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: -10s)\n  |> filter(fn: (r) => r._measurement == \"telemetry_live\")\n  |> filter(fn: (r) => r._field == \"RPM\")\n  |> filter(fn: (r) => r.session_id =~ /^${session_id:regex}$/)\n  |> filter(fn: (r) => r.source =~ /^${source:regex}$/)",
          "refId": "A"
        }
      ],
